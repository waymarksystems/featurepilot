{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "featurepilot",
  "compatibility_date": "2026-06-03",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
